# PostgreSQL
POSTGRES_DB=douban
POSTGRES_USER=douban_user
POSTGRES_PASSWORD=123456
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=change-me-to-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Superuser bootstrap
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=ChangeMe123!

# Migration bootstrap toggle
# 1/true/yes/on: startup uses alembic upgrade
# 0/false/no/off: fallback to SQLAlchemy create_all
RUN_ALEMBIC_UPGRADE=0
